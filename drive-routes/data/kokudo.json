":136.3329414}],"start_lat":34.481875,"start_lng":136.3644413,"end_lat":34.4988534,"end_lng":136.3329414,"length_km":4.42,"is_official":true},{"id":"24","name":"国道371号","description":"大阪府河内長野市から和歌山県串本町まで紀伊半島を縦断する国道。一部区間は1車線狭路で離合困難。龍神スカイラインとは別ルートの旧371号区間は深い山中を行く本格酷道。","category":"kokudo","prefecture":"大阪府・和歌山県・奈良県","polyline":[{"lat":33.4925044,"lng":135.7547787},{"lat":33.5377306,"lng":135.7403591},{"lat":33.5548989,"lng":135.6936672},{"lat":33.5772127,"lng":135.6758145},{"lat":33.5938012,"lng":135.6984738},{"lat":33.6578179,"lng":135.6868017},{"lat":33.7092602,"lng":135.6957272},{"lat":33.6952706,"lng":135.6565829},{"lat":33.685838,"lng":135.614703},{"lat":33.6521216,"lng":135.60509},{"lat":33.6686957,"lng":135.5789974},{"lat":33.6995494,"lng":135.5673245},{"lat":33.7378153,"lng":135.5769375},{"lat":33.7532311,"lng":135.5941036},{"lat":33.7703564,"lng":135.5899838},{"lat":33.78063,"lng":135.5659512},{"lat":33.7669316,"lng":135.5144528},{"lat":33.7760641,"lng":135.5027798}],"start_lat":33.4925044,"start_lng":135.7547787,"end_lat":33.7760641,"end_lng":135.5027798,"length_km":64.73,"is_official":true},{"id":"25","name":"国道378号","description":"愛媛県西予市から伊予市まで佐田岬半島の付け根を海岸沿いに走る国道。瀬戸内海と宇和海の海景を楽しめる夕やけこやけラインだが、半島突端へ向かう支線では狭路が点在する。","category":"kokudo","prefecture":"愛媛県","polyline":[{"lat":33.6091977,"lng":132.4700321},{"lat":33.5153616,"lng":132.3903812},{"lat":33.4672597,"lng":132.4068607},{"lat":33.4489281,"lng":132.4233402},{"lat":33.4030823,"lng":132.3793949},{"lat":33.3572123,"lng":132.3931278},{"lat":33.3824438,"lng":132.4205936},{"lat":33.3480354,"lng":132.4205936},{"lat":33.3227939,"lng":132.3793949},{"lat":33.2998407,"lng":132.4151005},{"lat":33.3159086,"lng":132.4727787},{"lat":33.3159086,"lng":132.516724},{"lat":33.2791777,"lng":132.549683},{"lat":33.2424314,"lng":132.5661625}],"start_lat":33.6091977,"start_lng":132.4700321,"end_lat":33.2424314,"end_lng":132.5661625,"length_km":68.43,"is_official":true},{"id":"26","name":"国道388号","description":"宮崎県延岡市から大分県豊後大野市・熊本県へ至る国道。耳川源流と九州山地を貫く山岳路線で、椎葉村～湯前間は深い山中の1.5車線路が続き、九州最深部の秘境ルートとして知られる。","category":"kokudo","prefecture":"宮崎県・大分県・熊本県","polyline":[{"lat":32.4745737,"lng":131.6205827},{"lat":32.4942669,"lng":131.5725175},{"lat":32.5232196,"lng":131.5436784},{"lat":32.5232196,"lng":131.503853},{"lat":32.5116397,"lng":131.513466},{"lat":32.4942669,"lng":131.4969865},{"lat":32.5023746,"lng":131.4434282},{"lat":32.4595321,"lng":131.4359818},{"lat":32.414309,"lng":131.4338151},{"lat":32.398077,"lng":131.3981096},{"lat":32.398077,"lng":131.3788835},{"lat":32.3748834,"lng":131.3678972},{"lat":32.398077,"lng":131.3239519},{"lat":32.3795226,"lng":131.3047258},{"lat":32.4177869,"lng":131.2484209},{"lat":32.3992365,"lng":131.1660234},{"lat":32.3510994,"lng":131.1428882},{"lat":32.3656043,"lng":131.112465},{"lat":32.3284783,"lng":131.0589067},{"lat":32.3052668,"lng":130.9998552}],"start_lat":32.4745737,"start_lng":131.6205827,"end_lat":32.3052668,"end_lng":130.9998552,"length_km":84.42,"is_official":true},{"id":"27","name":"国道399号","description":"福島県いわき市から山形県南陽市まで阿武隈・吾妻・東北を縦貫する国道。十文字峠・鳩峰峠など複数の険しい峠を越え、1車線狭路と急カーブが連続。東北を代表する酷道区間が点在。","category":"kokudo","prefecture":"福島県・山形県","polyline":[{"lat":37.7386314,"lng":140.6136817},{"lat":37.7321108,"lng":140.6358441},{"lat":37.7196151,"lng":140.6394637},{"lat":37.6949041,"lng":140.6722392},{"lat":37.6946348,"lng":140.6933326},{"lat":37.635932,"lng":140.7407112},{"lat":37.5820803,"lng":140.7592506},{"lat":37.549424,"lng":140.7393379},{"lat":37.4911513,"lng":140.7729835},{"lat":37.4606353,"lng":140.7537574},{"lat":37.4388306,"lng":140.7915229},{"lat":37.3910921,"lng":140.7999408},{"lat":37.3619004,"lng":140.80835},{"lat":37.3351712,"lng":140.8038826},{"lat":37.3231593,"lng":140.8382148},{"lat":37.301033,"lng":140.8364998},{"lat":37.2847115,"lng":140.8413926},{"lat":37.2656584,"lng":140.8373588},{"lat":37.251594,"lng":140.8450813},{"lat":37.1905974,"lng":140.8464647},{"lat":37.1596825,"lng":140.8574537},{"lat":37.1077117,"lng":140.8718605}],"start_lat":37.7386314,"start_lng":140.6136817,"end_lat":37.1077117,"end_lng":140.8718605,"length_km":81.84,"is_official":true},{"id":"28","name":"国道401号","description":"福島県会津若松市から新潟県小千谷市までを尾瀬周辺で結ぶ国道。沼山峠区間は車両通行不能で分断され、徒歩でのみ通行可能。残る区間も山深い1車線狭路を含む奥会津の難ルート。","category":"kokudo","prefecture":"福島県・群馬県・新潟県","polyline":[{"lat":36.9838227,"lng":139.3386948},{"lat":36.9953403,"lng":139.3627274},{"lat":37.0852268,"lng":139.4265854},{"lat":37.1076818,"lng":139.4540512},{"lat":37.1498354,"lng":139.4925034},{"lat":37.1667998,"lng":139.526149},{"lat":37.2176698,"lng":139.537822},{"lat":37.3236755,"lng":139.6545517}],"start_lat":36.9838227,"start_lng":139.3386948,"end_lat":37.3236755,"end_lng":139.6545517,"length_km":48.21,"is_official":true},{"id":"29","name":"国道410号","description":"千葉県木更津市から館山市まで房総半島を縦断する国道。鴨川市・南房総市の山間部に1.5車線狭隘区間が残り、トンネルや切り通しの旧道が点在。半島の山と海を結ぶ生活道路。","category":"kokudo","prefecture":"千葉県","polyline":[{"lat":35.2244313,"lng":140.0209915},{"lat":35.2116175,"lng":140.0265232},{"lat":35.1988037,"lng":140.0210686},{"lat":35.1849585,"lng":140.007416},{"lat":35.1464188,"lng":140.0153959},{"lat":35.124621,"lng":140.0159521},{"lat":35.1151779,"lng":140.0055238},{"lat":35.097769,"lng":139.9783181},{"lat":35.0744564,"lng":139.9579909},{"lat":35.038355,"lng":139.9526075},{"lat":35.0143406,"lng":139.9547786}],"start_lat":35.2244313,"start_lng":140.0209915,"end_lat":35.0143406,"end_lng":139.9547786,"length_km":26.23,"is_official":true},{"id":"30","name":"国道418号","description":"福井県大野市から長野県飯田市まで本州中央を横断する国道。徳山ダム湖周辺の旧道は崩落で長期通行止め、岐阜県八百津～恵那の不通区間と並び日本屈指の酷道として知られる。新旅足橋が著名。","category":"kokudo","prefecture":"福井県・岐阜県・長野県","polyline":[{"lat":35.9305068,"lng":136.5563729},{"lat":35.8259103,"lng":136.4410165},{"lat":35.7537808,"lng":136.5773156},{"lat":35.6361169,"lng":136.6126779},{"lat":35.5895587,"lng":136.7542352},{"lat":35.4989959,"lng":136.8976357},{"lat":35.4724382,"lng":137.0356515},{"lat":35.4846822,"lng":137.202329},{"lat":35.4788688,"lng":137.3182061},{"lat":35.3568804,"lng":137.3933938},{"lat":35.3675198,"lng":137.4311593},{"lat":35.3064644,"lng":137.4984505},{"lat":35.3277551,"lng":137.6220468},{"lat":35.3025419,"lng":137.6735452},{"lat":35.2593812,"lng":137.7449563},{"lat":35.2580065,"lng":137.8204554},{"lat":35.3176707,"lng":137.9221108}],"start_lat":35.9305068,"start_lng":136.5563729,"end_lat":35.3176707,"end_lng":137.9221108,"length_km":183.61,"is_official":true},{"id":"31","name":"国道424号","description":"和歌山県田辺市から紀の川市まで紀伊山地を貫く国道。山中の狭隘区間が断続し、急カーブと谷沿いの隘路が続く。沿線は果樹園と山村風景が広がる紀伊半島の山岳ルート。","category":"kokudo","prefecture":"和歌山県","polyline":[{"lat":34.1592056,"lng":135.274452},{"lat":34.1319282,"lng":135.2758253},{"lat":34.1228338,"lng":135.2895582},{"lat":34.0818969,"lng":135.2813185},{"lat":34.0636964,"lng":135.2538526},{"lat":34.0409403,"lng":135.2524794},{"lat":34.0363883,"lng":135.2813185},{"lat":34.0215927,"lng":135.2950514},{"lat":34.0136248,"lng":135.3389967},{"lat":33.9749129,"lng":135.3664625},{"lat":33.9498545,"lng":135.3664625},{"lat":33.9521329,"lng":135.3939283},{"lat":33.9658016,"lng":135.3939283},{"lat":33.953272,"lng":135.4296339},{"lat":33.9373226,"lng":135.4365004},{"lat":33.9156722,"lng":135.3953016},{"lat":33.9133929,"lng":135.4406202},{"lat":33.8880228,"lng":135.4423455},{"lat":33.8734952,"lng":135.4131544},{"lat":33.848407,"lng":135.3953016},{"lat":33.8358602,"lng":135.3513563},{"lat":33.800491,"lng":135.3238905},{"lat":33.7833717,"lng":135.317024}],"start_lat":34.1592056,"start_lng":135.274452,"end_lat":33.7833717,"end_lng":135.317024,"length_km":70.15,"is_official":true},{"id":"32","name":"国道425号","description":"三重県尾鷲市から和歌山県御坊市まで紀伊山地を横断する国道。落石・崩落・離合困難の三拍子が揃い、国道488・439と並ぶ日本三大酷道の筆頭格。携帯不通区間も多く本格装備が必須。","category":"kokudo","prefecture":"三重県・奈良県・和歌山県","polyline":[{"lat":33.8668971,"lng":135.1690876},{"lat":33.8674673,"lng":135.2652179},{"lat":33.920474,"lng":135.4334461},{"lat":33.8880228,"lng":135.4423455},{"lat":33.9688921,"lng":135.6229602},{"lat":33.9620675,"lng":135.6758292},{"lat":33.9785724,"lng":135.7190906},{"lat":33.9373756,"lng":135.7614468},{"lat":34.0395536,"lng":135.9652531},{"lat":34.0841553,"lng":136.1890488}],"start_lat":33.8668971,"start_lng":135.1690876,"end_lat":34.0841553,"end_lng":136.1890488,"length_km":106.63,"is_official":true},{"id":"33","name":"国道429号","description":"岡山県倉敷市から京都府福知山市まで中国山地を貫く国道。生野峠・榎峠・天王峠など複数の隘路を含み、1車線狭路と急勾配が連続。岡山・兵庫・京都の山間部を縫う長距離酷道。","category":"kokudo","prefecture":"岡山県・兵庫県・京都府","polyline":[{"lat":35.3035578,"lng":135.0984156},{"lat":35.2755343,"lng":135.0153315},{"lat":35.2665647,"lng":135.0180781},{"lat":35.2643222,"lng":135.0098384},{"lat":35.2553514,"lng":134.9967921},{"lat":35.2497441,"lng":134.9967921},{"lat":35.2402109,"lng":134.9425471},{"lat":35.2228239,"lng":134.9281276},{"lat":35.2250676,"lng":134.8937953},{"lat":35.2116045,"lng":134.8635829},{"lat":35.1841104,"lng":134.8409236},{"lat":35.192528,"lng":134.8354304},{"lat":35.1869164,"lng":134.8182643},{"lat":35.1717631,"lng":134.8155177},{"lat":35.1639048,"lng":134.8024714},{"lat":35.1683953,"lng":134.7907985},{"lat":35.1992614,"lng":134.7866786},{"lat":35.2160924,"lng":134.793545},{"lat":35.2446973,"lng":134.7715724},{"lat":35.25423,"lng":134.7331202},{"lat":35.2052198,"lng":134.6652699},{"lat":35.1797402,"lng":134.6084631},{"lat":35.1911836,"lng":134.5834074},{"lat":35.190943,"lng":134.5575655},{"lat":35.1626388,"lng":134.541344},{"lat":35.1481482,"lng":134.48546},{"lat":35.1639355,"lng":134.4062289},{"lat":35.1595574,"lng":134.3686207},{"lat":35.1239114,"lng":134.3288588},{"lat":35.0635146,"lng":134.2328721},{"lat":35.0766727,"lng":134.1513499},{"lat":35.0706693,"lng":134.0698207}],"start_lat":35.3035578,"start_lng":135.0984156,"end_lat":35.0706693,"end_lng":134.0698207,"length_km":119.52,"is_official":true},{"id":"34","name":"国道438号","description":"徳島県徳島市から香川県坂出市まで剣山系を越える国道。剣山スーパー林道に近接し、見ノ越・大川原高原周辺は1車線の急勾配と急カーブが連続。四国山地の屋根を越える山岳酷道。","category":"kokudo","prefecture":"徳島県・香川県","polyline":[{"lat":34.1966865,"lng":133.8590174},{"lat":34.160331,"lng":133.9002161},{"lat":34.145557,"lng":133.9510279},{"la