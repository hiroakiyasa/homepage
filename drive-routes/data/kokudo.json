:35.9766041,"start_lng":136.5100028,"end_lat":35.8793015,"end_lng":136.8533256,"length_km":45.36,"is_official":true},{"id":"6","name":"国道184号","description":"島根県出雲市と広島県尾道市を中国山地越えで結ぶ国道。県境の赤名峠周辺はかつて酷道区間が続いていたが、現在は改良が進む。それでも一部区間は山深い1.5車線路が残る。","category":"kokudo","prefecture":"島根県・広島県","polyline":[{"lat":35.3243499,"lng":132.7719126},{"lat":35.3036188,"lng":132.7629862},{"lat":35.2896082,"lng":132.7293406},{"lat":35.2643832,"lng":132.7231608},{"lat":35.254291,"lng":132.7066813},{"lat":35.2397111,"lng":132.6771555},{"lat":35.2161535,"lng":132.6757822},{"lat":35.1903444,"lng":132.6709757},{"lat":35.1836103,"lng":132.6833353},{"lat":35.1611591,"lng":132.6757822},{"lat":35.1089361,"lng":132.6984415},{"lat":35.0842168,"lng":132.7162943},{"lat":35.0679205,"lng":132.7066813},{"lat":35.0471238,"lng":132.7320871}],"start_lat":35.3243499,"start_lng":132.7719126,"end_lat":35.0471238,"end_lng":132.7320871,"length_km":37.84,"is_official":true},{"id":"7","name":"国道193号","description":"高松から剣山地を縦断し徳島県海陽町に至る国道。剣山系の県境付近は狭隘な1車線区間が連続し、ガードレールも乏しい山岳酷道。霧の多い高所と急峻な谷沿いを行く秘境ルート。","category":"kokudo","prefecture":"徳島県・香川県","polyline":[{"lat":34.0531108,"lng":134.2360335},{"lat":33.9962019,"lng":134.2799788},{"lat":33.9460904,"lng":134.2772323},{"lat":33.9244423,"lng":134.2580062},{"lat":33.845779,"lng":134.2744857},{"lat":33.7967203,"lng":134.3239241},{"lat":33.7955791,"lng":134.2964583},{"lat":33.7693265,"lng":134.2497664},{"lat":33.7247928,"lng":134.2813521},{"lat":33.7110855,"lng":134.3046981},{"lat":33.6756648,"lng":134.3115645},{"lat":33.6253652,"lng":134.3129378},{"lat":33.5956289,"lng":134.35139}],"start_lat":34.0531108,"start_lng":134.2360335,"end_lat":33.5956289,"end_lng":134.35139,"length_km":62.66,"is_official":true},{"id":"8","name":"国道256号","description":"岐阜市から長野県飯田市まで山岳地帯を縦断する国道。清内路峠周辺の旧道は狭く曲がりくねり、ところどころ離合困難な隘路となる。木曽山脈と恵那山系を越える長距離山岳路線。","category":"kokudo","prefecture":"岐阜県・長野県","polyline":[{"lat":35.7474626,"lng":136.9635785},{"lat":35.7318571,"lng":136.9979108},{"lat":35.7552641,"