g":131.0975696},{"lat":32.1373829,"lng":131.1305286},{"lat":32.1338942,"lng":131.1003162},{"lat":32.1059801,"lng":131.0769702},{"lat":32.0850388,"lng":131.0728504},{"lat":32.0640928,"lng":131.0769702},{"lat":32.0000613,"lng":130.9849597}],"start_lat":32.9293014,"start_lng":131.1291553,"end_lat":32.0000613,"end_lng":130.9849597,"length_km":133.04,"is_official":true},{"id":"10","name":"国道286号","description":"仙台と山形を笹谷峠経由で結ぶ国道。笹谷峠の旧道は急勾配と曲線の連続で冬期閉鎖、現在は笹谷トンネルが利用可。蔵王連峰の北側を抜ける東北の重要ルート。","category":"kokudo","prefecture":"宮城県・山形県","polyline":[{"lat":38.2374349,"lng":140.4054112},{"lat":38.2312324,"lng":140.4158825},{"lat":38.2255688,"lng":140.4357952},{"lat":38.2277264,"lng":140.4452366},{"lat":38.2279961,"lng":140.4756207},{"lat":38.2341989,"lng":140.4788822},{"lat":38.2294794,"lng":140.4922718},{"lat":38.2242202,"lng":140.5085796},{"lat":38.2259733,"lng":140.5132145},{"lat":38.2181514,"lng":140.5248875}],"start_lat":38.2374349,"start_lng":140.4054112,"end_lat":38.2181514,"end_lng":140.5248875,"length_km":11.87,"is_official":true},{"id":"11","name":"国道289号","description":"新潟県新潟市から福島県いわき市を結ぶ国道。八十里越（福島～新潟県境）が長らく自動車通行不能の分断区間で、近年バイパス整備が進む。甲子峠もかつて酷道として知られた。","category":"kokudo","prefecture":"新潟県・福島県","polyline":[{"lat":37.2488101,"lng":139.8709982},{"lat":37.205071,"lng":139.9080771},{"lat":37.1295615,"lng":140.1841086},{"lat":37.0737017,"lng":140.2980917},{"lat":37.0408237,"lng":140.3708761},{"lat":36.9859954,"lng":140.4024618},{"lat":36.9728307,"lng":140.4326742},{"lat":36.9870924,"lng":140.5466574},{"lat":36.9541769,"lng":140.5466574},{"lat":36.9651503,"lng":140.6098288},{"lat":36.8970897,"lng":140.775997}],"start_lat":37.2488101,"start_lng":139.8709982,"end_lat":36.8970897,"end_lng":140.775997,"length_km":97.03,"is_official":true},{"id":"12","name":"国道299号","description":"埼玉県入間市から長野県茅野市まで秩父・上信を横断する国道。十石峠（群馬・長野県境）は標高1351mの隘路で1車線狭隘区間が長く続き、冬期閉鎖。武田信玄の軍道に由来する古道。","category":"kokudo","prefecture":"埼玉県・群馬県・長野県","polyline":[{"lat":36.0900125,"lng":138.8277119},{"lat":36.081134,"lng":138.8225621},{"lat":36.0633741,"lng":138.8345784},{"lat":36.0594886,"lng":138.8445347},{"lat":36.0605987,"lng":138.8503712},{"lat":36.059211,"lng":138.8582676},{"lat":36.0569906,"lng":138.8555211},{"lat":36.0525496,"lng":138.8617009},{"lat":36.0467205,"lng":138.8881367},{"lat":36.0395028,"lng":138.8953465},{"lat":36.0325622,"lng":138.9372319},{"lat":36.0239549,"lng":138.9550847},{"lat":36.0228442,"lng":138.9667576},{"lat":36.0292304,"lng":138.9763707},{"lat":36.030341,"lng":138.9897603},{"lat":36.0217335,"lng":139.0058964}],"start_lat":36.0900125,"start_lng":138.8277119,"end_lat":36.0217335,"end_lng":139.0058964,"length_km":21.03,"is_official":true},{"id":"13","name":"国道308号","description":"大阪市と奈良市を最短で結ぶ国道。生駒山地を越える暗峠（くらがりとうげ）は最大斜度31%・道幅2.5mの石畳激坂で、日本一急な国道として全国の酷道愛好家に名高い名物区間。","category":"kokudo","prefecture":"大阪府・奈良県","polyline":[{"lat":34.6726123,"lng":135.651379},{"lat":34.6686592,"lng":135.6615928},{"lat":34.6659767,"lng":135.6724075},{"lat":34.6667532,"lng":135.6784156},{"lat":34.6677415,"lng":135.6821922},{"lat":34.6674592,"lng":135.6954101},{"lat":34.6656943,"lng":135.6993583},{"lat":34.664706,"lng":135.7082847}],"start_lat":34.6726123,"start_lng":135.651379,"end_lat":34.664706,"end_lng":135.7082847,"length_km":5.43,"is_official":true},{"id":"14","name":"国道309号","description":"大阪府松原市から三重県熊野市まで紀伊山地を横断する国道。大峰山系を越える行者還トンネル付近は曲がりくねった1.5車線路で、世界遺産・大峯奥駈道の登山口にもなる山岳酷道。","category":"kokudo","prefecture":"大阪府・奈良県・三重県","polyline":[{"lat":34.3753412,"lng":135.7857444},{"lat":34.3549366,"lng":135.7953575},{"lat":34.3515353,"lng":135.8070304},{"lat":34.3379289,"lng":135.8084037},{"lat":34.3305578,"lng":135.8166435},{"lat":34.3078735,"lng":135.8070304},{"lat":34.3022015,"lng":135.8138969},{"lat":34.3027687,"lng":135.8221367},{"lat":34.2789422,"lng":135.8406761},{"lat":34.2636216,"lng":135.831063},{"lat":34.2448926,"lng":135.8564689},{"lat":34.2255917,"lng":135.8777549},{"lat":34.2233207,"lng":135.8990409},{"lat":34.2062863,"lng":135.9127739},{"lat":34.2040148,"lng":135.9265068},{"lat":34.1886806,"lng":135.9278801},{"lat":34.1858406,"lng":135.9464195},{"lat":34.1920884,"lng":135.9663322},{"lat":34.1881126,"lng":135.9663322},{"lat":34.1896247,"lng":135.9960155}],"start_lat":34.3753412,"start_lng":135.7857444,"end_lat":34.1896247,"end_lng":135.9960155,"length_km":35.75,"is_official":true},{"id":"15","name":"国道310号","description":"大阪府堺市から奈良県五條市までを金剛山地経由で結ぶ国道。千早峠周辺は1車線で対向車が来ると離合困難な隘路となり、クルマ通行を躊躇するレベルの本格酷道区間が残る。","category":"kokudo","prefecture":"大阪府・奈良県","polyline":[{"lat":34.4133315,"lng":135.6286515},{"lat":34.398602,"lng":135.6324281},{"lat":34.3889698,"lng":135.646161},{"lat":34.3850032,"lng":135.6695069},{"lat":34.3852865,"lng":135.6753434},{"lat":34.3776363,"lng":135.6746568},{"lat":34.3711188,"lng":135.6774034},{"lat":34.3631839,"lng":135.6811799},{"lat":34.3575156,"lng":135.6849565}],"start_lat":34.4133315,"start_lng":135.6286515,"end_lat":34.3575156,"end_lng":135.6849565,"length_km":9.34,"is_official":true},{"id":"16","name":"国道319号","description":"香川県坂出市から高知県四万十市までを縦断する国道。徳島・高知県境付近の山中は1車線狭隘区間が長く続き、ガードレールの乏しい谷沿いの細道を行く四国を代表する酷道路線。","category":"kokudo","prefecture":"香川県・徳島県・高知県","polyline":[{"lat":33.9587283,"lng":133.5245808},{"lat":33.9433495,"lng":133.5259541},{"lat":33.925689,"lng":133.5266408},{"lat":33.92341,"lng":133.5444936},{"lat":33.9342349,"lng":133.5582265},{"lat":33.9348046,"lng":133.5767659},{"lat":33.945628,"lng":133.5904988},{"lat":33.9507544,"lng":133.6138448},{"lat":33.9627149,"lng":133.6186513},{"lat":33.9598673,"lng":133.6303243},{"lat":33.9473369,"lng":133.6406239},{"lat":33.9564501,"lng":133.648177},{"lat":33.9575892,"lng":133.6591634},{"lat":33.9564501,"lng":133.6783894},{"lat":33.9638539,"lng":133.6797627},{"lat":33.9649929,"lng":133.6893758},{"lat":33.9718265,"lng":133.6921224},{"lat":33.9610063,"lng":133.7202748}],"start_lat":33.9587283,"start_lng":133.5245808,"end_lat":33.9610063,"end_lng":133.7202748,"length_km":26.41,"is_official":true},{"id":"17","name":"国道327号","description":"宮崎県日向市から椎葉村方面に抜ける国道。耳川沿いを遡る山岳路線で、上流部では1.5車線の狭路と急カーブが連続。ダム湖と山並みの景観に恵まれた九州山地の秘境ルート。","category":"kokudo","prefecture":"宮崎県","polyline":[{"lat":32.4143298,"lng":131.6062699},{"lat":32.3865018,"lng":131.5300523},{"lat":32.4004169,"lng":131.5012132},{"lat":32.4120111,"lng":131.5046464},{"lat":32.4270815,"lng":131.4970933},{"lat":32.4265019,"lng":131.4689408},{"lat":32.4433083,"lng":131.4311753},{"lat":32.4421493,"lng":131.4229356},{"lat":32.4595321,"lng":131.4359818},{"lat":32.4653256,"lng":131.420189},{"lat":32.4566352,"lng":131.3858567},{"lat":32.4780701,"lng":131.3728105},{"lat":32.4931294,"lng":131.3796769},{"lat":32.5088948,"lng":131.3256972},{"lat":32.500079,"lng":131.3055192},{"lat":32.5093443,"lng":131.2993394},{"lat":32.5076071,"lng":131.269127},{"lat":32.4948668,"lng":131.2602006},{"lat":32.4670636,"lng":131.2155686},{"lat":32.4711188,"lng":131.1887895}],"start_lat":32.4143298,"start_lng":131.6062699,"end_lat":32.4711188,"end_lng":131.1887895,"length_km":54.15,"is_official":true},{"id":"18","name":"国道338号","description":"青森県下北半島の海沿いを北上し、本州最北の大間崎・尻屋崎方面を経由する国道。海岸線の狭隘区間や林の中の細道が続き、半島の荒涼とした風景を楽しめるが冬は厳しい雪と風に閉ざされる。","category":"kokudo","prefecture":"青森県","polyline":[{"lat":41.5080696,"lng":140.9190779},{"lat":41.4370707,"lng":140.8655195},{"lat":41.4108123,"lng":140.8428602},{"lat":41.3330045,"lng":140.8153944},{"lat":41.2932919,"lng":140.8057813},{"lat":41.2705882,"lng":140.8339338},{"lat":41.2329031,"lng":140.8256941},{"lat":41.2075955,"lng":140.7989149},{"lat":41.1776268,"lng":140.7982282},{"lat":41.1460933,"lng":140.8167677}],"start_lat":41.5080696,"start_lng":140.9190779,"end_lat":41.1460933,"end_lng":140.8167677,"length_km":44.45,"is_official":true},{"id":"19","name":"国道339号","description":"青森県津軽半島の最北端・龍飛岬を経由する国道。途中に日本唯一の階段国道（クルマ通行不能の階段区間）があることで全国的に有名。津軽海峡を望む風光明媚な海岸線を走る。","category":"kokudo","prefecture":"青森県","polyline":[{"lat":41.1847739,"lng":140.4742346},{"lat":41.1902066,"lng":140.450236},{"lat":41.2239142,"lng":140.4032075},{"lat":41.2436001,"lng":140.3848241},{"lat":41.2581163,"lng":140.3492597},{"lat":41.2224642,"lng":140.3621181},{"lat":41.2104438,"lng":140.3445992},{"lat":41.1975342,"lng":140.3380784},{"lat":41.1843614,"lng":140.3338323},{"lat":41.1687344,"lng":140.3301022},{"lat":41.1586695,"lng":140.3274567},{"lat":41.157628,"lng":140.3283253},{"lat":41.1544017,"lng":140.3252269},{"lat":41.1497477,"lng":140.3216252},{"lat":41.1462499,"lng":140.3199107}],"start_lat":41.1847739,"start_lng":140.4742346,"end_lat":41.1462499,"end_lng":140.3199107,"length_km":27.22,"is_official":true},{"id":"20","name":"国道340号","description":"岩手県陸前高田市から青森県八戸市まで北上山地を縦貫する国道。押角峠の旧道はトンネルが狭く曲がりくねった難所として知られた。改良後も山深い狭隘区間が断続的に残る東北の山岳酷道。","category":"kokudo","prefecture":"岩手県・青森県","polyline":[{"lat":40.0433633,"lng":141.4495396},{"lat":40.0181266,"lng":141.4598392},{"lat":39.8211712,"lng":141.7296909},{"lat":39.7958525,"lng":141.6802525},{"lat":39.6902575,"lng":141.6994785},{"lat":39.6035489,"lng":141.8093418},{"lat":39.5887341,"lng":141.6500401},{"lat":39.4743423,"lng":141.696732},{"lat":39.3873634,"lng":141.6006016},{"lat":39.3602888,"lng":141.5829064},{"lat":39.3353301,"lng":141.5405144},{"lat":39.3247139,"lng":141.5751957},{"lat":39.2518446,"lng":141.6009381},{"lat":39.1985297,"lng":141.5889209},{"lat":39.1909656,"lng":141.5563237},{"lat":39.1545573,"lng":141.5419626},{"lat":39.1381782,"lng":141.5722743},{"lat":39.0351629,"lng":141.6012882}],"start_lat":40.0433633,"start_lng":141.4495396,"end_lat":39.0351629,"end_lng":141.6012882,"length_km":152.57,"is_official":true},{"id":"21","name":"国道341号","description":"秋田県鹿角市から男鹿市までを八幡平経由で結ぶ国道。八幡平アスピーテラインに連なる高原ルートで、田沢湖・玉川温泉を経由。冬期は豪雪閉鎖となる東北の高所路線。","category":"kokudo","prefecture":"秋田県・岩手県","polyline":[{"lat":39.5011101,"lng":140.0464393},{"lat":39.504289,"lng":140.0945045},{"lat":39.5328923,"lng":140.1370765},{"lat":39.5297147,"lng":140.1700355},{"lat":39.5636012,"lng":140.2029944},{"lat":39.5508957,"lng":140.2139808},{"lat":39.539247,"lng":140.205741},{"lat":39.5286555,"lng":140.2332069},{"lat":39.5530135,"lng":140.2414466},{