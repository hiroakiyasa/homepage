.7498416},{"lat":32.0549836,"lng":130.7604846}],"start_lat":32.0773863,"start_lng":130.3831729,"end_lat":32.0549836,"end_lng":130.7604846,"length_km":40.43,"is_official":true},{"id":"41","name":"国道477号","description":"三重県四日市市から大阪府池田市まで近畿を東西に横断する国道。京都府の百井別れは1台分しか通れない極狭分岐として有名で、鈴鹿スカイラインや琵琶湖西岸など変化に富む酷道。","category":"kokudo","prefecture":"三重県・滋賀県・京都府・大阪府","polyline":[{"lat":35.0768664,"lng":135.5432851},{"lat":35.0903518,"lng":135.6064564},{"lat":35.1083289,"lng":135.5886037},{"lat":35.1285483,"lng":135.5789906},{"lat":35.146517,"lng":135.59959},{"lat":35.1319178,"lng":135.6119496},{"lat":35.146517,"lng":135.6201893},{"lat":35.1925435,"lng":135.6861073},{"lat":35.2071319,"lng":135.7382924},{"lat":35.2015213,"lng":135.783611},{"lat":35.1700948,"lng":135.783611},{"lat":35.1554998,"lng":135.7794911},{"lat":35.1521314,"lng":135.7987172},{"lat":35.1656043,"lng":135.8097035},{"lat":35.154377,"lng":135.8124501},{"lat":35.1498857,"lng":135.8275563},{"lat":35.146517,"lng":135.8385426}],"start_lat":35.0768664,"start_lng":135.5432851,"end_lat":35.146517,"end_lng":135.8385426,"length_km":47.03,"is_official":true},{"id":"42","name":"国道482号","description":"京都府宮津市から岡山県新見市まで中国山地北部を貫く全長300km近い長大国道。県境峠の連続と1車線狭路の多さで知られ、雪と霧に阻まれる冬季の難所が点在する山陰山陽縦断ルート。","category":"kokudo","prefecture":"京都府・兵庫県・鳥取県・岡山県","polyline":[{"lat":35.7272222,"lng":135.0963253},{"lat":35.7082676,"lng":135.1086849},{"lat":35.6630928,"lng":135.1004452},{"lat":35.6357524,"lng":135.0798458},{"lat":35.6044948,"lng":135.0805325},{"lat":35.5994701,"lng":135.0455136},{"lat":35.581602,"lng":135.0352139},{"lat":35.5704324,"lng":134.9782223},{"lat":35.5341205,"lng":134.9782223},{"lat":35.5140022,"lng":134.9912686},{"lat":35.4899655,"lng":134.9919552},{"lat":35.4905245,"lng":134.9802822},{"lat":35.4983512,"lng":134.9775357},{"lat":35.4977922,"lng":134.9589962},{"lat":35.4826971,"lng":134.9535031},{"lat":35.4675992,"lng":134.9473233},{"lat":35.4413109,"lng":134.9081845},{"lat":35.4508204,"lng":134.8711056},{"lat":35.4810197,"lng":13